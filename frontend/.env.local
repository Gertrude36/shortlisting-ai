# ─────────────────────────────────────────────────────────────
# frontend/.env.local  —  LOCAL DEVELOPMENT ONLY
#
# This file is loaded by Vite only in dev mode (npm run dev).
# It overrides frontend/.env for local work.
# NEVER commit this file — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────

# Points axios directly at your LOCAL backend (no Vite proxy needed).
VITE_API_URL=http://localhost:8000
